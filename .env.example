# Prisma / Neon runtime connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/work_tracker?schema=public"

# Required for auth sessions. Use a long random value in every deployed environment.
# Example: openssl rand -base64 32
SESSION_SECRET="replace-this-with-a-long-random-secret-before-production"

NEXT_TELEMETRY_DISABLED="1"

# Optional local demo seed
SEED_DEMO_EMAIL=""
SEED_DEMO_PASSWORD=""
SEED_DEMO_NAME="Demo User"
